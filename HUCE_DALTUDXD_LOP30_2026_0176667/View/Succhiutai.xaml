<Page x:Class="HUCE_DALTUDXD_LOP30_2026_0176667.View.Succhiutai"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Succhiutai"
      Height="656"
      Width="Auto"
      Background="Transparent">

    <Page.Resources>
        <Style x:Key="CompactTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource ModernTextBoxStyle}">
            <Setter Property="Width" Value="86" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="CompactFieldLabelTextStyle"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource FieldLabelTextStyle}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,6,8" />
        </Style>

        <Style x:Key="CompactUnitTextStyle"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource UnitTextStyle}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="5,0,0,0" />
        </Style>
    </Page.Resources>

    <Grid>
        <Frame x:Name="MainFrame"
               NavigationUIVisibility="Hidden" />

        <Border x:Name="ThongsomongPage"
                Style="{StaticResource PageChromeStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Frame x:Name="MainContentFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent" />

                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center">
                    <TextBlock Text="Khả năng chịu lực của nền đất"
                               Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="Kiểm tra áp lực tiêu chuẩn và áp lực lớn nhất theo sức chịu tải tính toán"
                               FontSize="14"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               TextAlignment="Center" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Padding="2,14,10,4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource SectionCardStyle}"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Thông số tính toán"
                                           Style="{StaticResource SectionTitleTextStyle}" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <GroupBox Grid.Column="0"
                                              Header="Thông số móng đơn"
                                              Style="{StaticResource ModernGroupBoxStyle}"
                                              Margin="0,0,8,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="95" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="45" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="Lực dọc N"
                                                       Style="{StaticResource CompactFieldLabelTextStyle}" />
                                            <TextBox Grid.Row="0"
                                                     Grid.Column="1"
                                                     Text="{Binding N}"
                                                     IsReadOnly="True"
                                                     Style="{StaticResource CompactTextBoxStyle}" />
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="2"
                                                       Text="kN"
                                                       Style="{StaticResource CompactUnitTextStyle}" />

                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="0"
                                                       Text="Mô-men M"
                                                       Style="{StaticResource CompactFieldLabelTextStyle}" />
                                            <TextBox Grid.Row="1"
                                                     Grid.Column="1"
                                                     Text="{Binding Momen}"
                                                     IsReadOnly="True"
                                                     Style="{StaticResource CompactTextBoxStyle}" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="2"
                                                       Text="kN.m"
                                                       Style="{StaticResource CompactUnitTextStyle}" />

                                            <TextBlock Grid.Row="2"
                                                       Grid.Column="0"
                                                       Text="Hệ số an toàn Fs"
                                                       Style="{StaticResource CompactFieldLabelTextStyle}" />
                                            <TextBox Grid.Row="2"
                                                     Grid.Column="1"
                                                     Text="{Binding Fs, Mode=TwoWay, Converter={StaticResource DecimalInputConverter}, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource CompactTextBoxStyle}" />

                                            <TextBlock Grid.Row="3"
                                                       Grid.Column="0"
                                                       Text="Góc ma sát"
                                                       Style="{StaticResource CompactFieldLabelTextStyle}" />
                                            <TextBox Grid.Row="3"
                                                     Grid.Column="1"
                                                     Text="{Binding GocMaSat, Mode=TwoWay, Converter={StaticResource DecimalInputConverter}, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource CompactTextBoxStyle}" />
                                            <TextBlock Grid.Row="3"
                                                       Grid.Column="2"
                                                       Text="độ"
                                                       Style="{StaticResource CompactUnitTextStyle}" />
                                        </Grid>
                                    </GroupBox>

                                    <GroupBox Grid.Column="1"
                                              Header="Hệ số tính toán"
                                              Style="{StaticResource ModernGroupBoxStyle}"
                                              Margin="8,0,8,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="95" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="Hệ số Nγ"
                                                       Style="{StaticResource CompactFieldLabelTextStyle}" />
                                            <TextBox Grid.Row="0"
                                                     Grid.Column="1"
                                                     Text="{Binding Ngamma, Mode=OneWay}"
                                                     IsReadOnly="True"
                                                     Style="{StaticResource CompactTextBoxStyle}" />

                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="0"
                                                       Text="Hệ số Nq"
                                                       Style="{StaticResource CompactFieldLabelTextStyle}" />
                                            <TextBox Grid.Row="1"
                                                     Grid.Column="1"
                                                     Text="{Binding Nq, Mode=OneWay}"
                                                     IsReadOnly="True"
                                                     Style="{StaticResource CompactTextBoxStyle}" />

                                            <TextBlock Grid.Row="2"
                                                       Grid.Column="0"
                                                       Text="Hệ số Nc"
                                                       Style="{StaticResource CompactFieldLabelTextStyle}" />
                                            <TextBox Grid.Row="2"
                                                     Grid.Column="1"
                                                     Text="{Binding Nc, Mode=OneWay}"
                                                     IsReadOnly="True"
                                                     Style="{StaticResource CompactTextBoxStyle}" />
                                        </Grid>
                                    </GroupBox>

                                    <GroupBox Grid.Column="2"
                                              Header="Sức chịu tải"
                                              Style="{StaticResource ModernGroupBoxStyle}"
                                              Margin="8,0,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="50" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="Ptx"
                                                       Style="{StaticResource CompactFieldLabelTextStyle}" />
                                            <TextBox Grid.Row="0"
                                                     Grid.Column="1"
                                                     Text="{Binding Ptx, Mode=OneWay}"
                                                     Style="{StaticResource CompactTextBoxStyle}" />
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="2"
                                                       Text="t/m²"
                                                       Style="{StaticResource CompactUnitTextStyle}" />

                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="0"
                                                       Text="Pmax"
                                                       Style="{StaticResource CompactFieldLabelTextStyle}" />
                                            <TextBox Grid.Row="1"
                                                     Grid.Column="1"
                                                     Text="{Binding Pmax, Mode=OneWay}"
                                                     Style="{StaticResource CompactTextBoxStyle}" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="2"
                                                       Text="t/m²"
                                                       Style="{StaticResource CompactUnitTextStyle}" />

                                            <TextBlock Grid.Row="2"
                                                       Grid.Column="0"
                                                       Text="Pmin"
                                                       Style="{StaticResource CompactFieldLabelTextStyle}" />
                                            <TextBox Grid.Row="2"
                                                     Grid.Column="1"
                                                     Text="{Binding Pmin, Mode=OneWay}"
                                                     Style="{StaticResource CompactTextBoxStyle}" />
                                            <TextBlock Grid.Row="2"
                                                       Grid.Column="2"
                                                       Text="t/m²"
                                                       Style="{StaticResource CompactUnitTextStyle}" />

                                            <TextBlock Grid.Row="3"
                                                       Grid.Column="0"
                                                       Text="Rd"
                                                       Style="{StaticResource CompactFieldLabelTextStyle}" />
                                            <TextBox Grid.Row="3"
                                                     Grid.Column="1"
                                                     Text="{Binding Rd, Mode=OneWay}"
                                                     Style="{StaticResource CompactTextBoxStyle}" />
                                            <TextBlock Grid.Row="3"
                                                       Grid.Column="2"
                                                       Text="t/m²"
                                                       Style="{StaticResource CompactUnitTextStyle}" />
                                        </Grid>
                                    </GroupBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Style="{StaticResource SectionCardStyle}"
                                Margin="0">
                            <StackPanel>
                                <TextBlock Text="Kết quả tính toán"
                                           Style="{StaticResource SectionTitleTextStyle}" />

                                <GroupBox Header="Điều kiện kiểm tra"
                                          Style="{StaticResource ModernGroupBoxStyle}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,0,0,8">
                                            <TextBlock Text="Điều kiện 1: Ptx ≤ Rđ: "
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AppPrimaryDarkBrush}" />
                                            <TextBlock Text="{Binding KiemTra1}" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,0,0,12">
                                            <TextBlock Text="Điều kiện 2: Pmax ≤ 1.2Rđ: "
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AppPrimaryDarkBrush}" />
                                            <TextBlock Text="{Binding KiemTra2}" />
                                        </StackPanel>

                                        <Border Padding="14"
                                                CornerRadius="8"
                                                Background="{StaticResource AppSurfaceBrush}"
                                                BorderBrush="{StaticResource AppBorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding KetQuaKiemTra}"
                                                       Foreground="{StaticResource AppTextBrush}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{StaticResource AppSurfaceBrush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14"
                        Margin="0,14,0,0">
                    <Button Content="Tính toán"
                            Command="{Binding TinhToanCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="170"
                            HorizontalAlignment="Center" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
