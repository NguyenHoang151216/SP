<Page x:Class="HUCE_DALTUDXD_LOP30_2026_0176667.View.Dolun"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Dolun"
      Height="656"
      Width="Auto"
      Background="Transparent">

    <Page.Resources>
        <Style x:Key="DoLunValueTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource ModernTextBoxStyle}">
            <Setter Property="Width" Value="180" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="DoLunUnitTextStyle"
               TargetType="{x:Type TextBlock}"
               BasedOn="{StaticResource UnitTextStyle}">
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
    </Page.Resources>

    <Grid>
        <Frame x:Name="MainFrame"
               NavigationUIVisibility="Hidden" />

        <Border x:Name="ThongsomongPage"
                Style="{StaticResource PageChromeStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Frame x:Name="MainContentFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent" />

                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center">
                    <TextBlock Text="Tính độ lún nền đất"
                               Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="Áp lực gây lún được tính từ thông số đất, móng và Ptx của mục sức chịu tải"
                               FontSize="14"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               TextAlignment="Center" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="2,14,10,4">
                    <StackPanel>
                        <Border Style="{StaticResource SectionCardStyle}"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Thông số độ lún"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="245" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Dung trọng riêng"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Grid.Row="0"
                                             Grid.Column="1"
                                             Text="{Binding DungTrongRieng, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Style="{StaticResource DoLunValueTextBoxStyle}" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="2"
                                               Text="kN/m³"
                                               Style="{StaticResource DoLunUnitTextStyle}" />

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="Chiều sâu chôn móng"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Text="{Binding ChieuSauChonMong, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Style="{StaticResource DoLunValueTextBoxStyle}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="2"
                                               Text="m"
                                               Style="{StaticResource DoLunUnitTextStyle}" />

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Text="Ptx"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding Ptx, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Style="{StaticResource DoLunValueTextBoxStyle}" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="2"
                                               Text="T/m²"
                                               Style="{StaticResource DoLunUnitTextStyle}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Kết quả"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="245" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Pgl"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Grid.Row="0"
                                             Grid.Column="1"
                                             Text="{Binding Pgl, Mode=OneWay, TargetNullValue=''}"
                                             IsReadOnly="True"
                                             Style="{StaticResource DoLunValueTextBoxStyle}" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="2"
                                               Text="T/m²"
                                               Style="{StaticResource DoLunUnitTextStyle}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{StaticResource AppSurfaceBrush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14"
                        Margin="0,14,0,0">
                    <Button Content="Tính toán"
                            Command="{Binding TinhToanDoLun}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="170"
                            HorizontalAlignment="Center" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
