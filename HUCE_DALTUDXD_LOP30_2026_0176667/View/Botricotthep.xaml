<Page x:Class="HUCE_DALTUDXD_LOP30_2026_0176667.View.Botricotthep"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      Title="Botricotthep"
      Height="656"
      Width="Auto"
      Background="Transparent">

    <Grid>
        <Frame x:Name="MainFrame"
               NavigationUIVisibility="Hidden" />

        <Border x:Name="ThongsomongPage"
                Style="{StaticResource PageChromeStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Frame x:Name="MainContentFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent" />

                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center">
                    <TextBlock Text="Bố trí cốt thép móng"
                               Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="Chọn đường kính, khoảng cách và kiểm tra diện tích cốt thép bố trí"
                               FontSize="14"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               TextAlignment="Center" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="2,14,10,4">
                    <StackPanel>
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Số liệu đầu vào"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="210" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Fa yêu cầu (cạnh dài)"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Grid.Row="0"
                                             Grid.Column="1"
                                             Text="{Binding FaYeuCauDai, Converter={StaticResource DecimalInputConverter}, UpdateSourceTrigger=LostFocus}"
                                             materialDesign:HintAssist.Hint="mm²"
                                             Style="{StaticResource ModernTextBoxStyle}" />

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="Fa yêu cầu (cạnh ngắn)"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Text="{Binding FaYeuCauNgan, Converter={StaticResource DecimalInputConverter}, UpdateSourceTrigger=LostFocus}"
                                             materialDesign:HintAssist.Hint="mm²"
                                             Style="{StaticResource ModernTextBoxStyle}" />

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Text="Lớp bảo vệ cốt thép"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding ChieuDayLopBaoVe, Converter={StaticResource DecimalInputConverter}, UpdateSourceTrigger=LostFocus}"
                                             materialDesign:HintAssist.Hint="m"
                                             Style="{StaticResource ModernTextBoxStyle}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Cốt thép theo phương cạnh dài"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="210" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Đường kính thép (mm)"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <ComboBox Grid.Row="0"
                                              Grid.Column="1"
                                              SelectedValue="{Binding DuongKinhThepDai, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Content"
                                              Style="{StaticResource ModernComboBoxStyle}">
                                        <ComboBoxItem>10</ComboBoxItem>
                                        <ComboBoxItem>12</ComboBoxItem>
                                        <ComboBoxItem>14</ComboBoxItem>
                                        <ComboBoxItem>16</ComboBoxItem>
                                        <ComboBoxItem>18</ComboBoxItem>
                                        <ComboBoxItem>20</ComboBoxItem>
                                        <ComboBoxItem>22</ComboBoxItem>
                                        <ComboBoxItem>25</ComboBoxItem>
                                        <ComboBoxItem>28</ComboBoxItem>
                                    </ComboBox>

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="Số lượng thanh"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Text="{Binding SoLuongThepDai, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Style="{StaticResource ModernTextBoxStyle}" />

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Text="Khoảng cách thanh (mm)"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding KhoangCachThepDai, Converter={StaticResource DecimalInputConverter}, UpdateSourceTrigger=LostFocus}"
                                             Style="{StaticResource ModernTextBoxStyle}" />

                                    <TextBlock Grid.Row="3"
                                               Grid.Column="0"
                                               Text="Diện tích cốt thép (mm²)"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Grid.Row="3"
                                             Grid.Column="1"
                                             Text="{Binding DienTichThepDai, Mode=OneWay, StringFormat={}{0:F2}}"
                                             IsReadOnly="True"
                                             Style="{StaticResource ModernTextBoxStyle}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Cốt thép theo phương cạnh ngắn"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="210" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Đường kính thép (mm)"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <ComboBox Grid.Row="0"
                                              Grid.Column="1"
                                              SelectedValue="{Binding DuongKinhThepNgan, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Content"
                                              Style="{StaticResource ModernComboBoxStyle}">
                                        <ComboBoxItem>10</ComboBoxItem>
                                        <ComboBoxItem>12</ComboBoxItem>
                                        <ComboBoxItem>14</ComboBoxItem>
                                        <ComboBoxItem>16</ComboBoxItem>
                                        <ComboBoxItem>18</ComboBoxItem>
                                        <ComboBoxItem>20</ComboBoxItem>
                                        <ComboBoxItem>22</ComboBoxItem>
                                        <ComboBoxItem>25</ComboBoxItem>
                                        <ComboBoxItem>28</ComboBoxItem>
                                    </ComboBox>

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="Số lượng thanh"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Text="{Binding SoLuongThepNgan, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Style="{StaticResource ModernTextBoxStyle}" />

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Text="Khoảng cách thanh (mm)"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding KhoangCachThepNgan, Converter={StaticResource DecimalInputConverter}, UpdateSourceTrigger=LostFocus}"
                                             Style="{StaticResource ModernTextBoxStyle}" />

                                    <TextBlock Grid.Row="3"
                                               Grid.Column="0"
                                               Text="Diện tích cốt thép (mm²)"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBox Grid.Row="3"
                                             Grid.Column="1"
                                             Text="{Binding DienTichThepNgan, Mode=OneWay, StringFormat={}{0:F2}}"
                                             IsReadOnly="True"
                                             Style="{StaticResource ModernTextBoxStyle}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{StaticResource AppSurfaceBrush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14"
                        Margin="0,14,0,0">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="Kiểm tra"
                                Command="{Binding TinhToanCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="150"
                                Margin="0,0,12,0" />
                        <Button Content="Lưu kết quả"
                                Command="{Binding LuuCommand}"
                                Style="{StaticResource SuccessButtonStyle}"
                                Width="150" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
