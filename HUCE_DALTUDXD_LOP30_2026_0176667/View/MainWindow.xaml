<Window x:Class="HUCE_DALTUDXD_LOP30_2026_0176667.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Phần mềm tính toán và thiết kế Móng Đơn"
        Height="900"
        Width="1300"
        Background="Transparent"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen">
    <Border CornerRadius="30"
            Padding="18"
            Background="#DCEDEF">
        <Border CornerRadius="26"
                Background="{StaticResource AppBackgroundBrush}"
                BorderBrush="White"
                BorderThickness="1">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="72" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="TopMenuPanel"
                        Grid.Row="0"
                        CornerRadius="20"
                        Background="{StaticResource AppSurfaceBrush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        Padding="10,8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18"
                                          Direction="270"
                                          Opacity="0.12"
                                          ShadowDepth="8"
                                          Color="#0A4850" />
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="210" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Móng đơn"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AppPrimaryDarkBrush}" />
                                <TextBlock Text="Tính toán và thiết kế"
                                           FontSize="11"
                                           Foreground="{StaticResource AppMutedTextBrush}"
                                           Margin="0,1,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <ScrollViewer Grid.Column="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      Focusable="False"
                                      Margin="8,0,10,0">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button x:Name="HomeTopButton"
                                        Style="{StaticResource NavButtonStyle}"
                                        Click="HomeButton_Click">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Trang chủ" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="DataTopButton"
                                        Style="{StaticResource NavButtonStyle}"
                                        Click="Nhapsolieu_Click">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Nhập dữ liệu" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="CheckMenuButton"
                                        Style="{StaticResource NavButtonStyle}"
                                        Click="CheckMenuButton_Click">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Kiểm tra" />
                                    </StackPanel>
                                </Button>

                                <Popup x:Name="CheckPopup"
                                       PlacementTarget="{Binding ElementName=CheckMenuButton}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade"
                                       VerticalOffset="8">
                                    <Border Background="{StaticResource AppSurfaceBrush}"
                                            BorderBrush="{StaticResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="8"
                                            MinWidth="210">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="22"
                                                              Direction="270"
                                                              Opacity="0.18"
                                                              ShadowDepth="10"
                                                              Color="#0A4850" />
                                        </Border.Effect>
                                        <StackPanel>
                                            <Button Style="{StaticResource NavButtonStyle}"
                                                    HorizontalContentAlignment="Left"
                                                    Click="SucchiutaiButton_Click">
                                                <TextBlock Text="Sức chịu tải" />
                                            </Button>
                                            <Button Style="{StaticResource NavButtonStyle}"
                                                    HorizontalContentAlignment="Left"
                                                    Click="DolunButton_Click">
                                                <TextBlock Text="Độ lún" />
                                            </Button>
                                            <Button Style="{StaticResource NavButtonStyle}"
                                                    HorizontalContentAlignment="Left"
                                                    Click="ChongdamthungButton_Click">
                                                <TextBlock Text="Chống đâm thủng" />
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Popup>

                                <Button x:Name="CalculateTopButton"
                                        Style="{StaticResource NavButtonStyle}"
                                        Click="TinhtoanButton_Click">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Tính cốt thép" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="RebarTopButton"
                                        Style="{StaticResource NavButtonStyle}"
                                        Click="BotriButton_Click">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Bố trí cốt thép" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="RunCalculationButton"
                                        Style="{StaticResource NavButtonStyle}"
                                        Click="RunCalculationButton_Click">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Xem số liệu" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Column="2"
                                Width="292"
                                Height="54"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0"
                                Padding="8,5"
                                CornerRadius="14"
                                Background="{StaticResource AppSurfaceAltBrush}"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="30" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="104" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="124" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="32" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Móng"
                                           FontSize="10"
                                           Foreground="{StaticResource AppMutedTextBrush}"
                                           VerticalAlignment="Top"
                                           Margin="2,-1,0,0" />
                                <ComboBox x:Name="MongSelector"
                                          Grid.Row="1"
                                          Grid.Column="0"
                                          Width="104"
                                          Height="30"
                                          MinHeight="30"
                                          Padding="8,1"
                                          Margin="0"
                                          MaxDropDownHeight="260"
                                          DisplayMemberPath="TenHienThi"
                                          SelectionChanged="MongSelector_SelectionChanged"
                                          Style="{StaticResource ModernComboBoxStyle}" />

                                <TextBlock Grid.Row="0"
                                           Grid.Column="2"
                                           Text="Lớp đất"
                                           FontSize="10"
                                           Foreground="{StaticResource AppMutedTextBrush}"
                                           VerticalAlignment="Top"
                                           Margin="2,-1,0,0" />
                                <ComboBox x:Name="DatSelector"
                                          Grid.Row="1"
                                          Grid.Column="2"
                                          Width="124"
                                          Height="30"
                                          MinHeight="30"
                                          Padding="8,1"
                                          Margin="0"
                                          MaxDropDownHeight="260"
                                          DisplayMemberPath="TenHienThi"
                                          SelectionChanged="DatSelector_SelectionChanged"
                                          Style="{StaticResource ModernComboBoxStyle}" />

                                <Button x:Name="ExitButton"
                                        Grid.Row="1"
                                        Grid.Column="4"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Width="30"
                                        Height="30"
                                        MinHeight="30"
                                        Padding="0"
                                        ToolTip="Thoát"
                                        Click="ExitButton_Click">
                                    <materialDesign:PackIcon Kind="Close"
                                                             Width="17"
                                                             Height="17"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center" />
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Margin="0,18,0,0"
                      ClipToBounds="True">
                    <Border CornerRadius="22"
                            Background="#EAF3F4"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            BorderThickness="1" />

                    <Frame x:Name="MainFrame"
                           NavigationUIVisibility="Hidden"
                           Background="Transparent" />

                    <Image x:Name="anhnen"
                           Source="/Resources/Images/huce.jpg"
                           Stretch="Fill"
                           Opacity="0.34">
                        <Image.Effect>
                            <BlurEffect Radius="5" />
                        </Image.Effect>
                    </Image>

                    <TextBlock x:Name="tieude"
                               Text="Phần mềm tính toán và thiết kế móng đơn"
                               FontSize="43"
                               FontFamily="Segoe UI Semibold"
                               FontWeight="Bold"
                               Foreground="{StaticResource AppPrimaryDarkBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Width="880"
                               Margin="0,54,0,0" />

                    <Border x:Name="login"
                            Width="470"
                            Height="430"
                            Background="#F7FFFFFF"
                            BorderBrush="White"
                            BorderThickness="1"
                            CornerRadius="24"
                            Padding="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24"
                                              Direction="270"
                                              Opacity="0.20"
                                              ShadowDepth="12"
                                              Color="#0A4850" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="220" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    CornerRadius="18"
                                    Background="{StaticResource AppSurfaceAltBrush}"
                                    BorderBrush="{StaticResource AppBorderBrush}"
                                    BorderThickness="1"
                                    Padding="10"
                                    ClipToBounds="True">
                                <Image Source="/Resources/Images/maytinh.png"
                                       Stretch="Uniform" />
                            </Border>

                            <TextBlock Grid.Row="1"
                                       Text="Thiết kế móng đơn"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AppPrimaryDarkBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,18,0,4" />

                            <TextBlock Grid.Row="2"
                                       Text="Nhập dữ liệu, kiểm tra nền đất, tính toán và bố trí cốt thép trong cùng một quy trình."
                                       FontSize="14"
                                       Foreground="{StaticResource AppMutedTextBrush}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="4,0" />

                            <StackPanel Grid.Row="3"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"
                                        Margin="0,18,0,0">
                                <Border Background="#E8F5F3"
                                        CornerRadius="12"
                                        Padding="12,8"
                                        Margin="0,0,8,0">
                                    <TextBlock Text="Số liệu"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AppPrimaryDarkBrush}" />
                                </Border>
                                <Border Background="#FFF5E8"
                                        CornerRadius="12"
                                        Padding="12,8"
                                        Margin="0,0,8,0">
                                    <TextBlock Text="Kiểm tra"
                                               FontWeight="SemiBold"
                                               Foreground="#7A4B04" />
                                </Border>
                                <Border Background="#EDF0FF"
                                        CornerRadius="12"
                                        Padding="12,8">
                                    <TextBlock Text="Cốt thép"
                                               FontWeight="SemiBold"
                                               Foreground="#35406D" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
