<Page x:Class="HUCE_DALTUDXD_LOP30_2026_0176667.View.Thongsomong"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      Title="ThongSoMong"
      Height="656"
      Width="Auto"
      Background="Transparent">

    <Grid>
        <Frame x:Name="MainFrame"
               NavigationUIVisibility="Hidden" />

        <Border x:Name="ThongsomongPage"
                Style="{StaticResource PageChromeStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,4">
                    <TextBlock Text="Thông số móng"
                               Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="Kích thước, tải trọng và vật liệu dùng cho quá trình kiểm tra móng đơn"
                               FontSize="14"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               TextAlignment="Center" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="2,12,10,4">
                    <StackPanel x:Name="DefaultDataInput"
                                Visibility="Visible">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Danh sách thông số móng theo lớp đất"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <Border Style="{StaticResource SoftPanelStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Lớp đất"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding DanhSachDat}"
                                                  SelectedItem="{Binding DatDuocChon, Mode=TwoWay}"
                                                  DisplayMemberPath="TenHienThi"
                                                  Style="{StaticResource ModernComboBoxStyle}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="Móng đang chọn"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox Grid.Column="3"
                                                  ItemsSource="{Binding DanhSachMong}"
                                                  SelectedItem="{Binding MongDuocChon, Mode=TwoWay}"
                                                  DisplayMemberPath="TenHienThi"
                                                  Style="{StaticResource ModernComboBoxStyle}" />
                                        <Button Grid.Column="4"
                                                Content="Tạo móng mới"
                                                Width="135"
                                                Margin="10,0,0,0"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Command="{Binding TaoMoiCommand}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Kích thước móng"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <Border Style="{StaticResource SoftPanelStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="210" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Chiều dài móng l (m)"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox x:Name="txtChieuDaiMong"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Text="{Binding ChieuDaiMong, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBoxStyle}" />

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="Chiều rộng móng b (m)"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox x:Name="txtChieuRongMong"
                                                 Grid.Row="1"
                                                 Grid.Column="1"
                                                 Text="{Binding ChieuRongMong, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBoxStyle}" />

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Text="Chiều cao móng hm (m)"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox x:Name="txtChieuCaoMong"
                                                 Grid.Row="2"
                                                 Grid.Column="1"
                                                 Text="{Binding ChieuCaoMong, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBoxStyle}" />

                                        <TextBlock Grid.Row="3"
                                                   Grid.Column="0"
                                                   Text="Chiều sâu chôn móng (m)"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox x:Name="txtChieuSauChonMong"
                                                 Grid.Row="3"
                                                 Grid.Column="1"
                                                 Text="{Binding ChieuSauChonMong, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBoxStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Thông tin tải trọng"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <Border Style="{StaticResource SoftPanelStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="210" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Tải trọng đứng N (T)"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox x:Name="txtTaiTrongN"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Text="{Binding TaiTrongN, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBoxStyle}" />

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="Tải trọng ngang Q (T)"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox x:Name="txtTaiTrongQ"
                                                 Grid.Row="1"
                                                 Grid.Column="1"
                                                 Text="{Binding TaiTrongQ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBoxStyle}" />

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Text="Mô-men M (T.m)"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox x:Name="txtMoMenM"
                                                 Grid.Row="2"
                                                 Grid.Column="1"
                                                 Text="{Binding MoMenM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBoxStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Thông tin vật liệu"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <Border Style="{StaticResource SoftPanelStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="210" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Mác bê tông"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox x:Name="cboMacBeTong"
                                                  Grid.Row="0"
                                                  Grid.Column="1"
                                                  ItemsSource="{Binding DanhSachMacBeTong}"
                                                  SelectedItem="{Binding SelectedMacBeTong, Mode=TwoWay}"
                                                  Style="{StaticResource ModernComboBoxStyle}" />

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="Loại cốt thép"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox x:Name="cboLoaiThep"
                                                  Grid.Row="1"
                                                  Grid.Column="1"
                                                  ItemsSource="{Binding DanhSachLoaiThep}"
                                                  SelectedItem="{Binding SelectedLoaiThep, Mode=TwoWay}"
                                                  Style="{StaticResource ModernComboBoxStyle}" />

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Text="Cường độ bê tông (MPa)"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox x:Name="txtCuongDoBeTong"
                                                 Grid.Row="2"
                                                 Grid.Column="1"
                                                 Text="{Binding CuongDoBeTong, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 Style="{StaticResource ModernTextBoxStyle}" />

                                        <TextBlock Grid.Row="3"
                                                   Grid.Column="0"
                                                   Text="Cường độ cốt thép (MPa)"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox x:Name="txtCuongDoThep"
                                                 Grid.Row="3"
                                                 Grid.Column="1"
                                                 Text="{Binding CuongDoThep, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 Style="{StaticResource ModernTextBoxStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Kích thước cột"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <Border Style="{StaticResource SoftPanelStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="210" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Chiều dài cột lc (m)"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox x:Name="txtChieuDaiCot"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Text="{Binding ChieuDaiCot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBoxStyle}" />

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="Chiều rộng cột bc (m)"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <TextBox x:Name="txtChieuRongCot"
                                                 Grid.Row="1"
                                                 Grid.Column="1"
                                                 Text="{Binding ChieuRongCot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBoxStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Các móng đã nhập cho lớp đất đang chọn"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <DataGrid Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          Height="150"
                                          ItemsSource="{Binding DanhSachMong}"
                                          SelectedItem="{Binding MongDuocChon, Mode=TwoWay}"
                                          Style="{StaticResource ModernDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="STT" Binding="{Binding IdMong}" Width="60" />
                                        <DataGridTextColumn Header="Tên móng" Binding="{Binding TenHienThi}" Width="110" />
                                        <DataGridTextColumn Header="L (m)" Binding="{Binding chieuDaiMong}" Width="90" />
                                        <DataGridTextColumn Header="B (m)" Binding="{Binding chieuRongMong}" Width="90" />
                                        <DataGridTextColumn Header="H (m)" Binding="{Binding chieuCaoMong}" Width="90" />
                                        <DataGridTextColumn Header="N (T)" Binding="{Binding N}" Width="90" />
                                        <DataGridTextColumn Header="Lớp đất" Binding="{Binding LopDat.TenHienThi}" Width="170" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{StaticResource AppSurfaceBrush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14"
                        Margin="0,14,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Thông số móng"
                                    Width="170"
                                    Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="Thongsodat"
                                    Content="Thông số đất"
                                    Width="170"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="Thongsodat_Click" />
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding LuuStatus}"
                                   Foreground="{StaticResource AppPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   Margin="12,0" />

                        <Button x:Name="Luusolieu"
                                Grid.Column="2"
                                Content="Lưu số liệu"
                                Width="170"
                                Style="{StaticResource SuccessButtonStyle}"
                                Command="{Binding LuuCommand}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
