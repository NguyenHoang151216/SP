<Page x:Class="HUCE_DALTUDXD_LOP30_2026_0176667.View.Thongsodat"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d"
      Title="Thongsodat"
      Height="656"
      Width="Auto"
      Background="Transparent">

    <Grid>
        <Frame x:Name="MainFrame"
               NavigationUIVisibility="Hidden" />

        <Border x:Name="ThongsodatPage"
                Style="{StaticResource PageChromeStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,4">
                    <TextBlock Text="Thông số đất"
                               Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="Khai báo lớp đất, trạng thái và các chỉ tiêu cơ lý để phục vụ kiểm tra nền"
                               FontSize="14"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               TextAlignment="Center" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="2,12,10,4">
                    <StackPanel x:Name="DefaultDataInput"
                                Visibility="Visible">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Danh sách thông số đất"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <Border Style="{StaticResource SoftPanelStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Lớp đất đang chọn"
                                                   Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding DanhSachDat}"
                                                  SelectedItem="{Binding DuLieuDuocChon, Mode=TwoWay}"
                                                  DisplayMemberPath="TenHienThi"
                                                  Style="{StaticResource ModernComboBoxStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Nhập thông tin lớp đất"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <Border Style="{StaticResource SoftPanelStyle}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="Loại đất"
                                                       Style="{StaticResource FieldLabelTextStyle}" />
                                            <ComboBox Grid.Row="0"
                                                      Grid.Column="1"
                                                      SelectedValue="{Binding LoaiDat, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Content"
                                                      Style="{StaticResource ModernComboBoxStyle}">
                                                <ComboBoxItem Content="Đất cát" />
                                                <ComboBoxItem Content="Đất sét" />
                                            </ComboBox>

                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="0"
                                                       Text="Trạng thái"
                                                       Style="{StaticResource FieldLabelTextStyle}" />
                                            <ComboBox Grid.Row="1"
                                                      Grid.Column="1"
                                                      SelectedValue="{Binding TrangThai, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Content"
                                                      Style="{StaticResource ModernComboBoxStyle}">
                                                <ComboBoxItem Content="Cứng" />
                                                <ComboBoxItem Content="Dẻo" />
                                                <ComboBoxItem Content="Mềm" />
                                            </ComboBox>

                                            <TextBlock Grid.Row="2"
                                                       Grid.Column="0"
                                                       Text="Góc ma sát (°)"
                                                       Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBox Grid.Row="2"
                                                     Grid.Column="1"
                                                     Text="{Binding GocMaSat, Converter={StaticResource DecimalInputConverter}, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource ModernTextBoxStyle}" />

                                            <TextBlock Grid.Row="3"
                                                       Grid.Column="0"
                                                       Text="Mô-đun nén ép (MPa)"
                                                       Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBox Grid.Row="3"
                                                     Grid.Column="1"
                                                     Text="{Binding ModunNenEp, Converter={StaticResource DecimalInputConverter}, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource ModernTextBoxStyle}" />

                                            <TextBlock Grid.Row="4"
                                                       Grid.Column="0"
                                                       Text="Lực dính (kPa)"
                                                       Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBox Grid.Row="4"
                                                     Grid.Column="1"
                                                     Text="{Binding LucDinh, Converter={StaticResource DecimalInputConverter}, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource ModernTextBoxStyle}" />

                                            <TextBlock Grid.Row="5"
                                                       Grid.Column="0"
                                                       Text="Chiều dày lớp đất (m)"
                                                       Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBox Grid.Row="5"
                                                     Grid.Column="1"
                                                     Text="{Binding ChieuDay, Converter={StaticResource DecimalInputConverter}, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource ModernTextBoxStyle}" />

                                            <TextBlock Grid.Row="6"
                                                       Grid.Column="0"
                                                       Text="Dung trọng riêng (kN/m³)"
                                                       Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBox Grid.Row="6"
                                                     Grid.Column="1"
                                                     Text="{Binding DungTrong, Converter={StaticResource DecimalInputConverter}, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource ModernTextBoxStyle}" />
                                        </Grid>

                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,6,0,0">
                                            <Button Content="Thêm lớp"
                                                    Width="120"
                                                    Style="{StaticResource SuccessButtonStyle}"
                                                    Command="{Binding ThemDatCommand}" />
                                            <Button Content="Xóa lớp"
                                                    Width="120"
                                                    Margin="10,0,0,0"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Command="{Binding XoaDatCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Chi tiết các lớp đất"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <DataGrid x:Name="SoilDataGrid"
                                          Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          Height="245"
                                          ItemsSource="{Binding DanhSachDat}"
                                          SelectedItem="{Binding DuLieuDuocChon}"
                                          Style="{StaticResource ModernDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="STT" Binding="{Binding IdDat}" Width="60" />
                                        <DataGridTextColumn Header="Loại đất" Binding="{Binding LoaiDat}" Width="95" />
                                        <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="100" />
                                        <DataGridTextColumn Header="Góc ma sát (°)" Binding="{Binding GocMaSat}" Width="125" />
                                        <DataGridTextColumn Header="Mô-đun nén ép (MPa)" Binding="{Binding ModunNenEp}" Width="160" />
                                        <DataGridTextColumn Header="Lực dính (kPa)" Binding="{Binding LucDinh}" Width="125" />
                                        <DataGridTextColumn Header="Dung trọng (kN/m³)" Binding="{Binding DungTrong}" Width="150" />
                                        <DataGridTextColumn Header="Chiều dày (m)" Binding="{Binding ChieuDay}" Width="130" />
                                        <DataGridTextColumn Header="Số móng" Binding="{Binding DanhSachMong.Count}" Width="90" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{StaticResource AppSurfaceBrush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14"
                        Margin="0,14,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Thông số đất"
                                    Width="170"
                                    Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="Thongsomong"
                                    Content="Thông số móng"
                                    Width="170"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="Thongsomong_Click" />
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="Lưu danh sách đất trước khi chuyển sang bước kiểm tra."
                                   Foreground="{StaticResource AppMutedTextBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   Margin="12,0" />

                        <Button x:Name="Luusolieu2"
                                Grid.Column="2"
                                Content="Lưu số liệu"
                                Width="170"
                                Style="{StaticResource SuccessButtonStyle}"
                                Click="Luusolieu2_Click" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
